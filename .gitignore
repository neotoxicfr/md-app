# ═══════════════════════════════════════════════════════════════════════════
# MD – .gitignore
# ═══════════════════════════════════════════════════════════════════════════
# Files and directories that must NEVER be committed to source control.
# Particularly important: secrets/, .env, data/ (user files)

# ── Environment & secrets (CRITICAL) ────────────────────────
# .env contains passwords, API keys, domains — never commit!
.env
.env.local
.env.*.local
# Docker secrets directory (redis_password, api_key, etc.)
secrets/

# ── Go build artifacts ───────────────────────────────────────
/build/
*.test
*.out
/vendor/
coverage.txt
coverage.html

# ── Node / SvelteKit frontend ───────────────────────────────
web/node_modules/            # npm dependencies (regenerated by npm ci)
web/dist/                    # SvelteKit build output (regenerated by npm run build)
web/.vite/                   # Vite cache
*.tsbuildinfo

# ── User data (never commit personal files!) ─────────────────
data/                        # markdown files stored by the app
redis_data/                  # Redis persistence (AOF + RDB)

# ── Docker ───────────────────────────────────────────────────
*.tar                        # exported Docker images

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Editor / OS ──────────────────────────────────────────────
.vscode/settings.json        # personal VS Code settings
.idea/                       # JetBrains IDE
*.swp                        # Vim swap files
.DS_Store                    # macOS
Thumbs.db                    # Windows

# ── TLS certificates ────────────────────────────────────────
certs/                       # production certificates
certs-staging/               # Let's Encrypt staging certs

# ── Misc ─────────────────────────────────────────────────────
# .sessions/                 # optional: work session tracking (uncomment to ignore)
*.pdf                        # exported PDFs (generated, not source)
