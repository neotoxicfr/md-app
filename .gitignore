# ═══════════════════════════════════════════════════════════════════════════
# MD – .gitignore
# ═══════════════════════════════════════════════════════════════════════════
# Files and directories that must NEVER be committed to source control.
# Particularly important: secrets/, .env, data/ (user files)

# ── Environment & secrets (CRITICAL) ────────────────────────
# .env contains passwords, API keys, domains — never commit!
.env
.env.local
.env.*.local
# Docker secrets directory (redis_password, api_key, etc.)
secrets/

# ── Go build artifacts ───────────────────────────────────────
/build/
*.test
*.out
/vendor/
coverage.txt
coverage.html

# ── Node / SvelteKit frontend ───────────────────────────────
# npm dependencies (regenerated by npm ci)
web/node_modules/
# SvelteKit build output (regenerated by npm run build)
web/dist/
# Vite cache
web/.vite/
*.tsbuildinfo

# ── User data (never commit personal files!) ─────────────────
# markdown files stored by the app at runtime
data/
# Redis persistence (AOF + RDB)
redis_data/

# ── Docker ───────────────────────────────────────────────────
# exported Docker images
*.tar

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Editor / OS ──────────────────────────────────────────────
# personal VS Code settings
.vscode/settings.json
# JetBrains IDE
.idea/
# Vim swap files
*.swp
# macOS
.DS_Store
# Windows
Thumbs.db

# ── TLS certificates ────────────────────────────────────────
# production certificates
certs/
# Let's Encrypt staging certs
certs-staging/

# ── Misc ─────────────────────────────────────────────────────
# .sessions/  # optional: uncomment to ignore work session tracking
# exported PDFs (generated, not source)
*.pdf
