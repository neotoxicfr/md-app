# ═══════════════════════════════════════════════════════════════════════════
# MD – Environment Variables (.env.example)
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to source control — it's in .gitignore.
#
# Secret precedence (Go app reads in this order):
#   1. Docker secret file  → /run/secrets/<name>   (preferred in production)
#   2. Environment variable → from .env or compose  (fallback / dev mode)
#
# For production, prefer Docker secrets over env vars:
#   mkdir -p secrets
#   openssl rand -base64 32 > secrets/redis_password
#   echo "your-api-key"   > secrets/api_key
#   echo ""               > secrets/oidc_client_secret
#   openssl rand -hex 32  > secrets/oidc_session_key
#
# ═══════════════════════════════════════════════════════════════════════════

# ── Build metadata ───────────────────────────────────────────
# Injected into the Go binary at compile time (see Dockerfile.app).
# Visible on the /health endpoint response.
APP_VERSION=1.0.0
GIT_SHA=local
BUILD_DATE=2026-01-01

# ── HTTP server ──────────────────────────────────────────────
# Internal listen address (inside the container)
MD_HTTP_ADDR=:8080

# Public-facing URL of the app (used for OIDC redirects, CORS, links)
# ⚠️  CHANGE to your own domain!
MD_APP_URL=https://md.example.com

# Allowed CORS origins (comma-separated if multiple)
MD_CORS_ORIGINS=https://md.example.com

# ── File storage ─────────────────────────────────────────────
# Path inside the container where markdown files are stored.
# Mapped to a volume or bind mount in docker-compose.
MD_STORAGE_PATH=/data

# Maximum upload file size in megabytes (default: 10)
MD_MAX_FILE_SIZE_MB=20

# ── API key (optional) ──────────────────────────────────────
# If set, every request must include header: X-API-Key: <value>
# Leave empty for public access (recommended for personal use).
# Production: prefer Docker secret → secrets/api_key
MD_API_KEY=

# ── Redis cache ──────────────────────────────────────────────
# Used by docker-compose.cloud.yml (full URL with password)
# For docker-compose.nas.yml, Redis password comes from Docker secret.
MD_REDIS_URL=redis://:changeme@md-redis:6379/0
REDIS_PASSWORD=changeme

# ── OIDC / SSO (optional) ───────────────────────────────────
# Single Sign-On via OpenID Connect (Authelia, Keycloak, Auth0, etc.)
# Leave MD_OIDC_ISSUER empty to disable OIDC entirely.
MD_OIDC_ISSUER=
MD_OIDC_CLIENT_ID=
# Production: prefer Docker secret → secrets/oidc_client_secret
MD_OIDC_CLIENT_SECRET=
# Callback URL registered with your OIDC provider
MD_OIDC_REDIRECT_URL=https://md.example.com/api/auth/callback
# Production: prefer Docker secret → secrets/oidc_session_key
MD_OIDC_SESSION_KEY=

# ── Traefik ──────────────────────────────────────────────────
# Used in docker-compose.cloud.yml Traefik labels.
# ⚠️  CHANGE to your own domain!
MD_DOMAIN=md.example.com

# ── Timezone ─────────────────────────────────────────────────
# IANA timezone for timestamps and logs (e.g. Europe/Paris, America/New_York)
TZ=UTC

# ── Export tools ─────────────────────────────────────────────
# Path to the Pandoc binary inside the container (usually "pandoc")
MD_PANDOC_BINARY=pandoc

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=production
